<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationIcon>app_icon.ico</ApplicationIcon>
    <AssemblyName>AurumVPN_Setup</AssemblyName>
    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>true</SelfContained>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
  </PropertyGroup>

  <ItemGroup>
    <EmbeddedResource Include="AurumVPN_payload.zip" />
  </ItemGroup>

  <Target Name="RequireInstallerInputs" BeforeTargets="BeforeBuild">
    <Error Condition="!Exists('AurumVPN_payload.zip')" Text="Copy AurumVPN_payload.zip into this folder before publishing the installer." />
    <Error Condition="!Exists('app_icon.ico')" Text="Copy app_icon.ico into this folder before publishing the installer." />
  </Target>
</Project>
